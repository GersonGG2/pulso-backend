# =============================
# App
# =============================
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# =============================
# Database
# =============================
DATABASE_URL="postgresql://pulso:pulso@localhost:5432/pulso_dev?schema=public"

# =============================
# Redis (cache, rate limiting)
# =============================
REDIS_URL="redis://localhost:6379"

# =============================
# Auth — Clerk
# =============================
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=

# =============================
# Riot Games API
# =============================
RIOT_API_KEY=
RIOT_REGION=americas
RIOT_PLATFORM_ROUTING=la1
# Tournament API (cuando llegue Production Key)
RIOT_TOURNAMENT_PROVIDER_ID=
RIOT_TOURNAMENT_CALLBACK_URL=

# =============================
# SMS verification (Twilio)
# =============================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# =============================
# Email (Resend)
# =============================
RESEND_API_KEY=
EMAIL_FROM="Pulso <noreply@pulsogg.gg>"

# =============================
# Payments — Stripe
# =============================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# =============================
# Payments — Mercado Pago
# =============================
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# =============================
# Observability
# =============================
SENTRY_DSN=
POSTHOG_API_KEY=
